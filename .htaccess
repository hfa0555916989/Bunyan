Options -Indexes
Options +FollowSymLinks
RewriteEngine On

# Force HTTPS
# RewriteCond %{HTTPS} off
# RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Force www
# RewriteCond %{HTTP_HOST} !^www\. [NC]
# RewriteRule ^(.*)$ https://www.%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Remove trailing slash
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)/$ /$1 [L,R=301]

# Clean URLs - remove .php extension
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME}.php -f
RewriteRule ^(.*)$ $1.php [L,QSA]

# Admin panel clean URL
RewriteRule ^admin332233/?$ /admin332233/index.php [L,QSA]
RewriteRule ^admin332233/dashboard/?$ /admin332233/dashboard.php [L,QSA]
RewriteRule ^admin332233/content/?$ /admin332233/content.php [L,QSA]
RewriteRule ^admin332233/settings/?$ /admin332233/settings.php [L,QSA]
RewriteRule ^admin332233/logout/?$ /admin332233/logout.php [L,QSA]
RewriteRule ^admin332233/upload/?$ /admin332233/upload.php [L,QSA]
RewriteRule ^admin332233/delete/?$ /admin332233/delete.php [L,QSA]

# Security headers
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options nosniff
    Header always set X-Frame-Options DENY
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# Cache static assets
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpg "access plus 1 year"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    ExpiresByType video/mp4 "access plus 1 year"
    ExpiresByType video/webm "access plus 1 year"
</IfModule>

# Gzip compression
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json text/xml
</IfModule>

# Protect sensitive files
<FilesMatch "\.(json|log|md)$">
    Order Allow,Deny
    Deny from all
</FilesMatch>

# Protect data directory
<IfModule mod_rewrite.c>
    RewriteRule ^data/ - [F,L]
</IfModule>

# Custom error pages
ErrorDocument 404 /index.php
